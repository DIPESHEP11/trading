# ─────────────────────────────────────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DB_NAME=traiding_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Meta / Facebook
# ─────────────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Business API
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=whatsapp_verify_token

# ─────────────────────────────────────────────────────────────────────────────
# Production (use config.settings.production)
# ─────────────────────────────────────────────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
SENTRY_DSN=
ALLOWED_HOSTS=trading.zitrapps.com,www.trading.zitrapps.com
CORS_ALLOWED_ORIGINS=https://trading.zitrapps.com,https://www.trading.zitrapps.com
FRONTEND_CLIENT_URL=https://trading.zitrapps.com
