# Superadmin frontend environment variables
# Copy to .env and customize

# API base URL (no trailing slash)
# Development — use http://localhost:8000 (not 127.0.0.1) unless you add 127.0.0.1 to tenants.Domain
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Production (same domain as backend):
# VITE_API_BASE_URL=https://trading.zitrapps.com/api/v1

VITE_APP_NAME=Trading Superadmin
VITE_APP_VERSION=1.0.0
